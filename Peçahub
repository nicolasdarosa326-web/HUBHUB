-- KILL AURA
_G.KillAura = false

KillAura.MouseButton1Click:Connect(function()

    _G.KillAura = not _G.KillAura

    while _G.KillAura do
        wait()

        pcall(function()

            for i,v in pairs(workspace.Enemies:GetChildren()) do

                if v:FindFirstChild("HumanoidRootPart") then

                    local mag = (chr.HumanoidRootPart.Position - v.HumanoidRootPart.Position).Magnitude

                    if mag <= 25 then

                        VirtualInputManager:SendMouseButtonEvent(
                            0,0,0,true,game,0
                        )

                    end
                end
            end
        end)
    end
end)

